      "statements": [
        {
          "kind": "sql_create_table",
          "target": "adam.ae_summary",
          "from": [
            "adam.adae"
          ],
          "join": [],
          "into_macro_var": null,
          "line": 50,
          "raw": "create table adam.ae_summary as\n  select\n    arm,\n    arm_decode,\n    aesev_std as severity,\n    count(*) as n_events,\n    sum(case when aeser='Y' then 1 else 0 end) as n_serious\n  from adam.adae\n  where trtemfl = 'Y'\n  group by arm, arm_decode, aesev_std\n  order by arm, aesev_std"
        }
      ],
