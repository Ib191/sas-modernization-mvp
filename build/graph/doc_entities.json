    {
      "file": "sas_codebase/docs/data_dictionary.md",
      "sections": [
        {
          "title": "CTX-2024-001 Data Dictionary",
          "level": 1,
          "line_start": 1,
          "datasets": [],
          "columns": [],
          "bullets": [],
          "open_issues": [],
          "body_preview": " This dictionary documents column-level semantics for the raw inputs and ADaM outputs. Format: `column \u2014 type \u2014 description`. "
        },
        {
          "title": "RAW.DM",
          "level": 2,
          "line_start": 6,
          "datasets": [
            "site_lookup"
          ],
          "columns": [
            "AGE",
            "ARM",
            "BRTHDTC",
            "DRUG_X_HI",
            "DRUG_X_LOW",
            "PLACEBO",
            "RACE",
            "RECORDCREATEDT",
            "RFENDTC",
            "RFSTDTC",
            "SEX",
            "SITEID",
            "USUBJID"
          ],
          "bullets": [
            {
              "line": 8,
              "text": "`USUBJID` \u2014 char(20) \u2014 Unique subject identifier. Format `CTX-NNN`. **Primary key after dedup.**"
            },
            {
              "line": 9,
              "text": "`AGE` \u2014 num \u2014 Age in years at reference start. May be missing; derive from `BRTHDTC` if so."
            },
            {
              "line": 10,
              "text": "`SEX` \u2014 char(1) \u2014 `M`, `F`, `U`. Decoded via `$sexfmt`."
            },
            {
              "line": 11,
              "text": "`RACE` \u2014 char(20) \u2014 Free-form, controlled by CRF dropdown."
            },
            {
              "line": 12,
              "text": "`ARM` \u2014 char(20) \u2014 Treatment arm code: `PLACEBO`, `DRUG_X_LOW`, `DRUG_X_HI`."
            },
            {
              "line": 13,
              "text": "`SITEID` \u2014 **char(2)** \u2014 Site identifier with leading zeros. *Note:* differs in type from `SITE_LOOKUP.SITE_ID`."
            },
            {
              "line": 14,
              "text": "`BRTHDTC` \u2014 char(10) \u2014 ISO 8601 date of birth."
            },
            {
              "line": 15,
              "text": "`RFSTDTC` \u2014 char(10) \u2014 ISO 8601 reference start (first dose)."
            },
            {
              "line": 16,
              "text": "`RFENDTC` \u2014 char(10) \u2014 ISO 8601 reference end (last dose / end of treatment)."
            },
            {
              "line": 17,
              "text": "`RECORDCREATEDT` \u2014 char(10) \u2014 ISO 8601, set by EDC. Used for dedup tiebreak."
            }
          ],
          "open_issues": [],
          "body_preview": " - `USUBJID` \u2014 char(20) \u2014 Unique subject identifier. Format `CTX-NNN`. **Primary key after dedup.** - `AGE` \u2014 num \u2014 Age in years at reference start. May be missing; derive from `BRTHDTC` if so. - `SEX` \u2014 char(1) \u2014 `M`, `F`, `U`. Decoded via `$sexfmt`."
        },
        {
          "title": "RAW.AE",
          "level": 2,
          "line_start": 19,
          "datasets": [],
          "columns": [
            "AEENDTC",
            "AESER",
            "AESEV",
            "AESTDTC",
            "AETERM",
            "MILD",
            "MOD",
            "MODERATE",
            "SEV",
            "SEVERE",
            "USUBJID"
          ],
          "bullets": [
            {
              "line": 21,
              "text": "`USUBJID` \u2014 char(20) \u2014 FK to DM."
            },
            {
              "line": 22,
              "text": "`AETERM` \u2014 char(60) \u2014 Reported term (free text). Not standardized to MedDRA in v1.3."
            },
            {
              "line": 23,
              "text": "`AESEV` \u2014 char(20) \u2014 Severity, raw. May contain `MILD`/`MODERATE`/`MOD`/`SEVERE`/`SEV`/`1`/`2`/`3`/`GRADE 1`/`GRADE 2`/`GRADE 3`."
            },
            {
              "line": 24,
              "text": "`AESER` \u2014 char(1) \u2014 `Y`/`N`. Serious AE indicator."
            },
            {
              "line": 25,
              "text": "`AESTDTC` \u2014 char(10) \u2014 Onset date, ISO 8601. May be missing."
            },
            {
              "line": 26,
              "text": "`AEENDTC` \u2014 char(10) \u2014 End date, ISO 8601. Often missing for ongoing events."
            }
          ],
          "open_issues": [],
          "body_preview": " - `USUBJID` \u2014 char(20) \u2014 FK to DM. - `AETERM` \u2014 char(60) \u2014 Reported term (free text). Not standardized to MedDRA in v1.3. - `AESEV` \u2014 char(20) \u2014 Severity, raw. May contain `MILD`/`MODERATE`/`MOD`/`SEVERE`/`SEV`/`1`/`2`/`3`/`GRADE 1`/`GRADE 2`/`GRADE 3`."
        },
        {
          "title": "RAW.SITE_LOOKUP",
          "level": 2,
          "line_start": 28,
          "datasets": [],
          "columns": [
            "APAC",
            "EU",
            "LATAM",
            "NA",
            "SITE_COUNTRY",
            "SITE_ID",
            "SITE_NAME",
            "SITE_REGION"
          ],
          "bullets": [
            {
              "line": 30,
              "text": "`SITE_ID` \u2014 **num** \u2014 Site identifier. *Note:* numeric, vs char in DM."
            },
            {
              "line": 31,
              "text": "`SITE_NAME` \u2014 char(60)"
            },
            {
              "line": 32,
              "text": "`SITE_COUNTRY` \u2014 char(3) \u2014 ISO 3166-1 alpha-3."
            },
            {
              "line": 33,
              "text": "`SITE_REGION` \u2014 char(10) \u2014 `NA`, `EU`, `APAC`, `LATAM`."
            }
          ],
          "open_issues": [],
          "body_preview": " - `SITE_ID` \u2014 **num** \u2014 Site identifier. *Note:* numeric, vs char in DM. - `SITE_NAME` \u2014 char(60) - `SITE_COUNTRY` \u2014 char(3) \u2014 ISO 3166-1 alpha-3."
        },
        {
          "title": "ADAM.DM_CLEAN (output)",
          "level": 2,
          "line_start": 35,
          "datasets": [],
          "columns": [
            "AGEGRP",
            "AGE_DERIVED",
            "ARM_DECODE",
            "BRTHDTC",
            "RECORDCREATEDT",
            "RFENDT",
            "RFENDTC",
            "RFSTDT",
            "RFSTDTC",
            "SEX_DECODE",
            "TRTDURD"
          ],
          "bullets": [],
          "open_issues": [],
          "body_preview": " Adds derived columns: `AGE_DERIVED`, `AGEGRP`, `SEX_DECODE`, `ARM_DECODE`, `RFSTDT` (numeric date), `RFENDT` (numeric date), `TRTDURD`. Drops `BRTHDTC`, `RFSTDTC`, `RFENDTC`, `RECORDCREATEDT` from the keep list."
        },
        {
          "title": "ADAM.AE_CLEAN (output)",
          "level": 2,
          "line_start": 41,
          "datasets": [],
          "columns": [
            "AEDUR",
            "AEENDT",
            "AESEQ",
            "AESEVN",
            "AESEV_STD",
            "AESTDT",
            "MAX_AESEV",
            "MAX_AESEVN"
          ],
          "bullets": [],
          "open_issues": [],
          "body_preview": " Adds: `AESEQ` (within-subject sequence), `AESTDT`, `AEENDT`, `AEDUR`, `AESEV_STD`, `AESEVN`, `MAX_AESEV`, `MAX_AESEVN`. "
        },
        {
          "title": "ADAM.ADSL (output)",
          "level": 2,
          "line_start": 46,
          "datasets": [
            "dm_clean"
          ],
          "columns": [
            "ITTFL",
            "SAFFL",
            "SITE_COUNTRY",
            "SITE_NAME",
            "SITE_REGION"
          ],
          "bullets": [],
          "open_issues": [],
          "body_preview": " DM_CLEAN columns plus site descriptors and population flags: `SITE_NAME`, `SITE_COUNTRY`, `SITE_REGION`, `SAFFL`, `ITTFL`. "
        },
        {
          "title": "ADAM.ADAE (output)",
          "level": 2,
          "line_start": 51,
          "datasets": [
            "ae_clean"
          ],
          "columns": [
            "AGE",
            "AGEGRP",
            "ARM",
            "ARM_DECODE",
            "ASTDY",
            "ITTFL",
            "ONTRTFL",
            "RFENDT",
            "RFSTDT",
            "SAFFL",
            "SEX",
            "TRTEMFL"
          ],
          "bullets": [],
          "open_issues": [],
          "body_preview": " AE_CLEAN columns plus subject context: `AGE`, `AGEGRP`, `SEX`, `ARM`, `ARM_DECODE`, `RFSTDT`, `RFENDT`, `SAFFL`, `ITTFL`, `TRTEMFL`, `ONTRTFL`, `ASTDY`."
        },
        {
          "title": "ADAM.AE_SUMMARY (output)",
          "level": 2,
          "line_start": 57,
          "datasets": [],
          "columns": [
            "ARM",
            "ARM_DECODE",
            "N_EVENTS",
            "N_SERIOUS",
            "SEVERITY"
          ],
          "bullets": [],
          "open_issues": [],
          "body_preview": " Grouped counts: `ARM`, `ARM_DECODE`, `SEVERITY`, `N_EVENTS`, `N_SERIOUS`. Filtered to `TRTEMFL = 'Y'`. "
        },
        {
          "title": "ADAM.AE_INCIDENCE (output)",
          "level": 2,
          "line_start": 62,
          "datasets": [],
          "columns": [
            "ARM",
            "ARM_DECODE",
            "INCIDENCE_RATE",
            "N_SUBJ_TOTAL",
            "N_SUBJ_WITH_AE",
            "WORST_SEVERITY",
            "WORST_SEVERITY_RANK"
          ],
          "bullets": [],
          "open_issues": [],
          "body_preview": " Subject-level worst severity rates: `ARM`, `ARM_DECODE`, `WORST_SEVERITY`, `WORST_SEVERITY_RANK`, `N_SUBJ_WITH_AE`, `N_SUBJ_TOTAL`, `INCIDENCE_RATE`."
        }
      ]
    }
  ],
